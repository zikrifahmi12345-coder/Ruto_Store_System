    <script>
        // Sticky header shrink on scroll - optimized for smooth performance
        (function() {
            const header = document.querySelector('.rc-hero');
            const mainContent = document.querySelector('.rc-main');
            let isScrolled = false;
            let ticking = false;
            let lastScrollY = 0;
            
            // Wider hysteresis to prevent jittering
            const SCROLL_DOWN_THRESHOLD = 80;
            const SCROLL_UP_THRESHOLD = 20;
            
            function updateHeader() {
                const scrollY = window.scrollY;
                
                // Only update if there's a significant change
                if (Math.abs(scrollY - lastScrollY) < 5 && isScrolled === (scrollY > SCROLL_DOWN_THRESHOLD)) {
                    ticking = false;
                    return;
                }
                
                lastScrollY = scrollY;
                
                if (!isScrolled && scrollY > SCROLL_DOWN_THRESHOLD) {
                    header.classList.add('is-scrolled');
                    if (mainContent) mainContent.classList.add('header-scrolled');
                    isScrolled = true;
                }
                else if (isScrolled && scrollY < SCROLL_UP_THRESHOLD) {
                    header.classList.remove('is-scrolled');
                    if (mainContent) mainContent.classList.remove('header-scrolled');
                    isScrolled = false;
                }
                
                ticking = false;
            }
            
            function requestTick() {
                if (!ticking) {
                    window.requestAnimationFrame(updateHeader);
                    ticking = true;
                }
            }
            
            window.addEventListener('scroll', requestTick, { passive: true });
            
            // Initial check
            updateHeader();
        })();
    </script>
    
